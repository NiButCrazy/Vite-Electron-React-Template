{
  "name": "vite-electron-react-ts-template",
  "version": "0.0.0",
  "description": "a electron app",
  "type": "module",
  "main": ".out/main/index.js",
  "author": "Ni But Crazy",
  "license": "MIT",
  "scripts": {
    "start": "chcp 65001 && electron-vite preview ",
    "dev": "chcp 65001 && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:app",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "version": "git cliff && git add CHANGELOG.md"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@unocss/reset": "^66.6.7",
    "clsx": "^2.1.1",
    "globals": "^17.4.0",
    "immer": "^11.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.12.0",
    "use-immer": "^0.11.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "less": "^4.6.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "unocss": "^66.6.7",
    "vite": "^7.3.2"
  }
}
